Kintsugi [target: 'interpreter]

; --- Data Processing with capture ---
; capture extracts keyword-structured records from a block and
; returns a context where every @keyword maps to a block of
; matches. Combined with object and sort/by, it composes a
; small data pipeline without parser machinery.

raw: [
  student "Alice"   [90 85 92]
  student "Bob"     [78 82 88]
  student "Charlie" [95 91 87]
  student "Diana"   [88 94 96]
]

records: capture raw [
  @student [string! block!]
]

StudentRecord: object [
  field/required [name [string!]]
  field/required [scores [block!]]

  average: function [] [
    total: 0
    loop [for [s] in self/scores do [total: total + s]]
    total / (length self/scores)
  ]
]

students: loop/collect [
  for [row] in records/student do [
    make StudentRecord [
      name:   first row
      scores: second row
    ]
  ]
]

ranked: sort/by students function [s] [negate s/average]

loop [
  for [s] in ranked do [
    print rejoin ["  " s/name " - avg: " round s/average]
  ]
]

;   Diana - avg: 93
;   Charlie - avg: 91
;   Alice - avg: 89
;   Bob - avg: 83
